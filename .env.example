# PlantDoc AI Configuration
# Copy this file to .env and fill in your API key

OPENAI_API_KEY=sk-your-api-key-here

# Web search (optional — fallback simulated results used if not set)
# Get a free key at https://tavily.com
TAVILY_API_KEY=tvly-your-api-key-here

# Optional overrides (defaults shown)
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# LOG_LEVEL=INFO

# Deployment (backend)
CORS_ORIGINS=comma,separated,list,of,origins
MAX_UPLOAD_MB=10

# Deployment (frontend) — set when backend is on a different host
PLANTDOC_API_BASE=http://localhost:8000
